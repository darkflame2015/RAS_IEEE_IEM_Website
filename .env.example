# ───────────────────────────────────────────
#  ENVIRONMENT VARIABLES TEMPLATE
#  Copy this file to .env.local and fill in your actual values.
#  On Vercel, set these in: Project Settings → Environment Variables
#  NEVER commit .env.local — it is git-ignored.
# ───────────────────────────────────────────

# ── Resend API Key (Primary email provider) ──
# Sign up: https://resend.com → API Keys → Create
RESEND_API_KEY=re_your_api_key_here

# ── EmailJS (Fallback email provider) ──
# Dashboard: https://dashboard.emailjs.com
EMAILJS_PUBLIC_KEY=your_emailjs_public_key
EMAILJS_SERVICE_ID=your_emailjs_service_id
EMAILJS_TEMPLATE_ID=your_emailjs_template_id

# ── Contact form recipient email ──
CONTACT_RECIPIENT=your_email@example.com

# ── Site URL (for origin validation in API routes) ──
# After Vercel deploy, update to your production URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000
