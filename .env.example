# ╔═══════════════════════════════════════════════════════════════════╗
# ║  IEEE RAS STUDENT CHAPTER — ENVIRONMENT VARIABLES TEMPLATE      ║
# ║                                                                 ║
# ║  HOW TO USE:                                                    ║
# ║    1. Copy this file:  cp .env.example .env.local               ║
# ║    2. Replace all placeholder values with your real keys        ║
# ║    3. Never commit .env.local (it's already in .gitignore)      ║
# ║                                                                 ║
# ║  FOR VERCEL DEPLOYMENT:                                         ║
# ║    → Don't use this file. Instead set each variable in:         ║
# ║      Vercel Dashboard → Your Project → Settings → Env Variables ║
# ╚═══════════════════════════════════════════════════════════════════╝


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 1. RESEND — Primary Email Provider  [REQUIRED]
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#
# Sign up → https://resend.com (free: 100 emails/day, 3,000/month)
#
# Steps:
#   1. Create account at resend.com
#   2. Sidebar → "API Keys" → "Create API Key"
#   3. Name: "IEEE RAS Website" → Access: "Sending access" → Create
#   4. Copy the key (starts with "re_") — you only see it once!
#
# Free plan limitation: emails are sent FROM "onboarding@resend.dev"
# To use a custom sender domain, add it under Resend → Domains
#
RESEND_API_KEY=re_paste_your_resend_api_key_here


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 2. EMAILJS — Fallback Email Provider  [OPTIONAL]
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#
# Used ONLY when Resend fails. Optional but gives reliability.
# Sign up → https://www.emailjs.com (free: 200 emails/month)
#
# Steps for PUBLIC KEY:
#   1. Log in to EmailJS → Account → General tab
#   2. Copy "Public Key" (looks like: "aBcDeFgHiJkLm")
#
# Steps for SERVICE ID:
#   1. EmailJS Dashboard → "Email Services" → "Add New Service"
#   2. Choose Gmail / Outlook / etc. → Connect your account
#   3. Copy the "Service ID" shown (looks like: "service_abc123")
#
# Steps for TEMPLATE ID:
#   1. EmailJS Dashboard → "Email Templates" → "Create New Template"
#   2. In the template body, use these placeholders:
#        {{from_name}}   — submitter's full name
#        {{from_email}}  — submitter's email address
#        {{phone}}       — submitter's phone number
#        {{message}}     — the inquiry / message text
#        {{to_email}}    — your receiving email (auto-filled)
#   3. Save the template → Copy the "Template ID" (looks like: "template_xyz789")
#
EMAILJS_PUBLIC_KEY=paste_your_emailjs_public_key_here
EMAILJS_SERVICE_ID=paste_your_emailjs_service_id_here
EMAILJS_TEMPLATE_ID=paste_your_emailjs_template_id_here


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 3. CONTACT FORM SETTINGS  [REQUIRED]
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#
# All contact form submissions will be emailed to this address.
# Change this to the email of the person managing inquiries.
#
CONTACT_RECIPIENT=your_email@example.com


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 4. SITE URL — API Security  [REQUIRED]
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#
# Used for origin validation. The contact API rejects requests
# from domains that don't match this URL (prevents abuse).
#
# LOCAL DEVELOPMENT → http://localhost:3000
# AFTER VERCEL DEPLOY → https://your-project.vercel.app
#
# ⚠️  After your first deploy, update this to your real Vercel URL!
#
NEXT_PUBLIC_SITE_URL=http://localhost:3000
